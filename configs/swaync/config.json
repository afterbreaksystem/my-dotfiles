{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "right",
  "positionY": "top",

  "layer": "overlay",
  "control-center-layer": "top",
  "layer-shell": true,
  "cssPriority": "user",

  "control-center-margin-top": 10,
  "control-center-margin-bottom": 0,
  "control-center-margin-right": 10,
  "control-center-margin-left": 0,

  "notification-window-width": 400,
  "notification-window-max-height": 200,

  "notification-icon-size": 48,
  "notification-body-image-height": 100,
  "notification-body-image-width": 100,

  "timeout": 5,
  "timeout-low": 5,
  "timeout-critical": 0,

  "fit-to-screen": true,
  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "transition-time": 200,

  "hide-on-clear": false,
  "hide-on-action": true,
  "script-fail-notify": true,

  "control-center-width": 360,
  "control-center-height": 600,

  "widgets": ["buttons-grid", "dnd", "title", "notifications"],

  "widget-config": {
    "title": {
      "text": "Notifications",
      "clear-all-button": true,
      "button-text": "󰎟"
    },
    "backlight": {
      "label": "󰃟"
    },
    "dnd": {
      "text": "Do Not Disturb"
    },
    "label": {
      "max-lines": 1,
      "text": "Notification"
    },
    "buttons-grid": {
      "actions": [
        { "label": "󰐥", "command": "wlogout -b 4" },
        { "label": "󰌾", "command": "hyprlock" },
        { "label": "󰍃", "command": "hyprctl dispatch exit" },
        { "label": "", "command": "hyprpicker -a" },
        { "label": "󰝟", "command": "pactl set-sink-mute @DEFAULT_SINK@ toggle" }
      ]
    }
  }
}


{
    "workbench.colorTheme": "Monochromator Dark Amethyst",
    "editor.fontFamily": "'JetBrainsMono Nerd Font', 'JetBrains Mono', 'monospace', monospace",
    "workbench.colorCustomizations": {
        "statusBar.background": "{{colors.surface.default.hex}}",
        "statusBar.noFolderBackground": "{{colors.surface.default.hex}}",
        "statusBar.debuggingBackground": "{{colors.error_container.default.hex}}",
        "panel.background": "{{colors.surface.default.hex}}",
        "activityBar.background": "{{colors.surface.default.hex}}",
        "sideBar.background": "{{colors.surface.default.hex}}",
        "editor.background": "{{colors.surface.default.hex}}"
    },
    "editor.tokenColorCustomizations": {
        "functions": "{{colors.primary.default.hex}}",
        "keywords": "{{colors.secondary.default.hex}}",
        "numbers": "{{colors.tertiary.default.hex}}",
        "strings": "{{colors.primary_container.default.hex}}",
        "types": "{{colors.on_surface.default.hex}}",
        "variables": "{{colors.on_surface_variant.default.hex}}",
        "comments": "{{colors.outline.default.hex}}"
    },
    "editor.fontSize": 17,
    "editor.cursorBlinking": "phase",
    "editor.cursorSmoothCaretAnimation": "on",
    "security.workspace.trust.untrustedFiles": "open",
    "workbench.activityBar.location": "top",
    "workbench.secondarySideBar.defaultVisibility": "visible",
    "chat.commandCenter.enabled": false,
    "php.validate.executablePath": "/usr/bin/php",
    "python.defaultInterpreterPath": "/bin/python"
}
